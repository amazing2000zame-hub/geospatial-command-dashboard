# Geospatial Dashboard Environment Config

# CesiumJS (free tier - 500K tiles/mo)
# REQUIRED: Register at https://cesium.com/ion/ and set your token
CESIUM_ION_TOKEN=your_token_here

# Phase 1 - Data Sources
USGS_EARTHQUAKE_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
NWS_ALERTS_URL=https://api.weather.gov/alerts/active
NWS_USER_AGENT=GeospatialDashboard/1.0 (homelab@localhost)

# Phase 2
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Phase 3-4
NASA_FIRMS_API_KEY=
OPENAQ_API_KEY=
EPA_AIRNOW_API_KEY=

# Redis
REDIS_URL=redis://redis:6379

# Server
PORT=4010
NODE_ENV=production
